# Halo 环境变量配置
# 复制此文件为 .env 并填入实际值

# Tushare Pro Token (https://tushare.pro)
# 用于获取精确的财务数据和PE/PB历史分位
TUSHARE_TOKEN=your_tushare_token_here

# OpenAI API Key (可选)
# 用于AI增强分析：护城河评分、行业景气度、财报分析、风险识别
OPENAI_API_KEY=your_openai_api_key_here

# 数据源配置
# 是否启用实时数据采集（默认true）
ENABLE_LIVE_DATA=true

# 缓存过期时间（小时）
CACHE_TTL_HOURS=4

# Vercel Cron Jobs 鉴权密钥（必填）
# Vercel Cron Jobs 通过 Authorization: Bearer <CRON_SECRET> 自动发送
# 部署到Vercel后必须在项目Settings > Environment Variables中配置
# 本地开发设置 CRON_SECRET=dev 即可
CRON_SECRET=your_cron_secret_here
